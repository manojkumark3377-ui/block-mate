{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "complexity": 3,
  "description": "Added vercel.json for backend deployment configuration",
  "emptyFile": false,
  "isArtifact": false,
  "overwrite": true,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
